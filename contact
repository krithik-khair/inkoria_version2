<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>INKORIA — Contact Us</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      background: #FCFAF5;
      color: #2C2A29;
      font-family: 'Inter', sans-serif;
      line-height: 1.5;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      user-select: none;
      -webkit-user-select: none;
    }

    input, textarea, button {
      user-select: text;
      -webkit-user-select: text;
    }

    .container {
      max-width: 780px;
      width: 100%;
      background: white;
      border-radius: 32px;
      padding: 48px 40px;
      box-shadow: 0 20px 40px -12px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.02);
      border: 1px solid #E8E0D3;
      margin: 0 auto;
      transition: opacity 0.25s ease;
    }

    .fade-out {
      opacity: 0;
    }

    .icon {
      width: 72px;
      height: 72px;
      background: #FCFAF5;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      border: 1px solid #E8E0D3;
      font-size: 36px;
      font-family: 'Cormorant Garamond', serif;
      color: #C6A15B;
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 36px;
      font-weight: 500;
      margin-bottom: 8px;
      color: #2C2A29;
      text-align: center;
    }

    .subhead {
      text-align: center;
      color: #6B5E4A;
      margin-bottom: 32px;
      font-size: 15px;
    }

    .form-group {
      margin-bottom: 24px;
    }

    label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #2C2A29;
      margin-bottom: 6px;
      letter-spacing: 0.02em;
    }

    input, textarea {
      width: 100%;
      padding: 14px 18px;
      border-radius: 16px;
      border: 1px solid #E8E0D3;
      background: #FCFAF5;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      transition: all 0.2s;
      outline: none;
    }

    input:focus, textarea:focus {
      border-color: #C6A15B;
      box-shadow: 0 0 0 2px rgba(198,161,91,0.2);
    }

    textarea {
      resize: vertical;
      min-height: 120px;
    }

    button {
      width: 100%;
      background: #2C2A29;
      color: #FCFAF5;
      border: none;
      padding: 14px;
      border-radius: 40px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      margin-top: 8px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    button:hover {
      background: #C6A15B;
      transform: translateY(-2px);
    }

    .btn-loading {
      pointer-events: none;
      opacity: 0.85;
    }
    .btn-loading .btn-text {
      visibility: hidden;
    }
    .btn-loading::after {
      content: "";
      position: absolute;
      width: 18px;
      height: 18px;
      top: calc(50% - 9px);
      left: calc(50% - 9px);
      border-radius: 50%;
      border: 2px solid rgba(255,255,240,0.3);
      border-top-color: #D4AF37;
      border-right-color: #C6A15B;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .back-link {
      text-align: center;
      margin-top: 32px;
    }
    .back-link a {
      color: #6B5E4A;
      text-decoration: none;
      font-size: 13px;
      transition: color 0.2s;
      cursor: pointer;
    }
    .back-link a:hover {
      color: #C6A15B;
    }

    .custom-modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(44,42,41,0.4);
      backdrop-filter: blur(4px);
      z-index: 2000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s;
    }
    .custom-modal-overlay.active {
      opacity: 1;
      visibility: visible;
    }
    .custom-modal {
      background: #FCFAF5;
      max-width: 460px;
      width: 90%;
      border-radius: 28px;
      box-shadow: 0 30px 45px -12px rgba(0,0,0,0.25);
      text-align: center;
      padding: 36px 32px;
      transform: translateY(20px);
      transition: transform 0.25s ease;
      border: 1px solid #E8E0D3;
      margin: 16px;
    }
    .custom-modal-overlay.active .custom-modal {
      transform: translateY(0);
    }
    .custom-modal h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      margin-bottom: 12px;
    }
    .custom-modal p {
      color: #6B5E4A;
      margin-bottom: 24px;
    }
    .modal-btn {
      padding: 10px 28px;
      border-radius: 40px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: 0.2s;
      border: none;
      background: #2C2A29;
      color: white;
      font-family: inherit;
    }
    .modal-btn:hover {
      background: #C6A15B;
    }

    @media (max-width: 640px) {
      body { padding: 16px; }
      .container { padding: 32px 24px; border-radius: 28px; }
      .icon { width: 60px; height: 60px; font-size: 30px; margin-bottom: 20px; }
      h1 { font-size: 28px; }
      .subhead { font-size: 14px; }
      input, textarea { padding: 12px 16px; font-size: 13px; }
      button { padding: 12px; font-size: 14px; }
    }
    @media (max-width: 480px) {
      .container { padding: 28px 20px; }
      h1 { font-size: 26px; }
    }
  </style>
</head>
<body>

<div class="container" id="contactContainer">
  <div class="icon">֍</div>
  <h1>Write to us</h1>
  <p class="subhead">We’ll respond as soon as we can — usually within 24 hours.</p>

  <form id="contactForm" action="https://formspree.io/f/xkoajarg" method="POST">
    <div class="form-group">
      <label>Your name</label>
      <input type="text" name="name" placeholder="e.g. Krithik Khair" required>
    </div>
    <div class="form-group">
      <label>Email address</label>
      <input type="email" name="email" placeholder="you@example.com" required>
    </div>
    <div class="form-group">
      <label>Message</label>
      <textarea name="message" placeholder="What would you like to share with us?" required></textarea>
    </div>
    <button type="submit" id="submitBtn">
      <span class="btn-text">Send message →</span>
    </button>
  </form>

  <div class="back-link">
    <a href="#" id="backLink">← Back to INKORIA</a>
  </div>
</div>

<div id="customModal" class="custom-modal-overlay">
  <div class="custom-modal">
    <h3 id="modalTitle"></h3>
    <p id="modalMessage"></p>
    <button class="modal-btn" id="modalCloseBtn">Understood</button>
  </div>
</div>

<script>
  const form = document.getElementById('contactForm');
  const submitBtn = document.getElementById('submitBtn');
  const container = document.getElementById('contactContainer');
  const backLink = document.getElementById('backLink');

  // Smooth fade-out transition for back link
  backLink.addEventListener('click', (e) => {
    e.preventDefault();
    container.classList.add('fade-out');
    setTimeout(() => {
      window.location.href = 'https://inkoriabooks.com';
    }, 250);
  });

  // Form submission with fallback
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.classList.add('btn-loading');

    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        showModal("Message sent", "Thank you for reaching out. We'll get back to you soon.", () => {
          form.reset();
        });
      } else {
        // Fallback: traditional submit
        form.submit();
      }
    } catch (error) {
      form.submit();
    } finally {
      submitBtn.classList.remove('btn-loading');
    }
  });

  function showModal(title, message, onClose = null) {
    const overlay = document.getElementById('customModal');
    document.getElementById('modalTitle').innerText = title;
    document.getElementById('modalMessage').innerText = message;
    overlay.classList.add('active');
    const closeModal = () => {
      overlay.classList.remove('active');
      if (onClose) onClose();
    };
    document.getElementById('modalCloseBtn').onclick = closeModal;
    overlay.onclick = (e) => { if (e.target === overlay) closeModal(); };
  }

  // Copy protection
  document.addEventListener('contextmenu', (e) => {
    const tag = e.target.tagName.toLowerCase();
    if (tag !== 'input' && tag !== 'textarea' && tag !== 'button') e.preventDefault();
  });
  document.querySelectorAll('img').forEach(img => {
    img.setAttribute('draggable', 'false');
    img.addEventListener('dragstart', (e) => e.preventDefault());
  });
</script>
</body>
</html>
